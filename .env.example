# SaudiSaaSHub Environment Configuration
# Copy this file to .env and fill in the values

# ============================================
# Site Configuration
# ============================================
SITE_URL=https://saudisaashub.com
SITE_NAME=سعودي ساس هب
SITE_NAME_EN=SaudiSaaSHub
SITE_DESCRIPTION=مصدرك الأول لأحدث أخبار وتقارير SaaS والشركات الناشئة في المملكة العربية السعودية
SITE_DESCRIPTION_EN=Your premier source for the latest SaaS news and startup reports in the Kingdom of Saudi Arabia

# ============================================
# Google Analytics 4
# ============================================
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET= # Optional: for Measurement Protocol

# ============================================
# Database (if using backend API)
# ============================================
DATABASE_URL= # e.g., postgresql://user:pass@host:port/db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=saudisaashub
DATABASE_USER= # your database user
DATABASE_PASSWORD= # your database password

# ============================================
# API Configuration
# ============================================
API_BASE_URL=/api
API_ENABLED=true
CORS_ORIGINS=https://saudisaashub.com,https://www.saudisaashub.com

# ============================================
# Content Sources (optional)
# ============================================
CONTENT_API_KEY= # API key for external content sources
CONTENT_UPDATE_INTERVAL=3600 # seconds

# ============================================
# Email & Communications
# ============================================
SMTP_HOST= # your SMTP host
SMTP_PORT=587
SMTP_USER= # your SMTP username
SMTP_PASS= # your SMTP password
SMTP_FROM=noreply@saudisaashub.com
SMTP_FROM_NAME=سعودي ساس هب

# ============================================
# Newsletter (if implemented)
# ============================================
NEWSLETTER_PROVIDER= # e.g., mailchimp, sendgrid, convertkit
NEWSLETTER_API_KEY=
NEWSLETTER_LIST_ID=

# ============================================
# Social Media
# ============================================
TWITTER_HANDLE=@SaudiSaaSHub
TWITTER_CARD_TYPE=summary_large_image
FACEBOOK_APP_ID=
FACEBOOK_PAGE_ID=

# ============================================
# Search (if implementing custom search)
# ============================================
SEARCH_PROVIDER=algolia # or typesense, meilisearch
SEARCH_API_KEY=
SEARCH_APP_ID=
SEARCH_INDEX_NAME=saudisaashub

# ============================================
# File Storage (for company logos, images)
# ============================================
STORAGE_PROVIDER=local # or aws, gcp, azure
STORAGE_BUCKET= # if using cloud storage
STORAGE_REGION= # e.g., us-east-1
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# ============================================
# CDN & Performance
# ============================================
CDN_URL= # e.g., https://cdn.saudisaashub.com
ASSETS_VERSION=1.0.0 # cache busting

# ============================================
# Security
# ============================================
JWT_SECRET= # Generate with: openssl rand -base64 32
SESSION_SECRET= # Generate with: openssl rand -base64 32
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Monitoring & Error Tracking
# ============================================
SENTRY_DSN= # for error tracking
LOG_LEVEL=info # debug, info, warn, error

# ============================================
# Feature Flags
# ============================================
FEATURE_NEWSLETTER=true
FEATURE_COMPARISON=true
FEATURE_REVIEWS=true
FEATURE_RATINGS=true
FEATURE_COMPANIES_SUBMIT=true

# ============================================
# SEO & Structured Data
# ============================================
ORGANIZATION_NAME=سعودي ساس هب
ORGANIZATION_LOGO=https://saudisaashub.com/assets/images/logo.png
ORGANIZATION_URL=https://saudisaashub.com
ORGANIZATION_SAME_AS= # comma-separated social profiles

# ============================================
# Legal & Compliance
# ============================================
PRIVACY_POLICY_URL=https://saudisaashub.com/privacy
TERMS_OF_SERVICE_URL=https://saudisaashub.com/terms
CONTACT_EMAIL=contact@saudisaashub.com

# ============================================
# Development
# ============================================
NODE_ENV=production
DEBUG=false
PORT=3000

# ============================================
# Notes:
# - All values prefixed with # are optional or have defaults
# - For production, ensure all secrets are strong and unique
# - Never commit .env file to version control
# - Use environment-specific .env files: .env.production, .env.staging
# - For GitHub Pages, most backend configs are not applicable (static hosting)