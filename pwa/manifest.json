{
  "name": "SaudiSaaSHub - Your Gateway to Saudi SaaS",
  "short_name": "SaaS Hub",
  "description": {
    "ar": "الدليل الشامل لأفضل حلول SaaS في السوق السعودي. اكتشف، قارن، وقيّم أكثر من 500+ أداة سحابية.",
    "en": "Your comprehensive guide to the best SaaS solutions in the Saudi market. Discover, compare, and rate 500+ cloud tools."
  },
  "start_url": "/?utm_source=pwa&utm_medium=manifest",
  "scope": "/",
  "display": "standalone",
  "display_override": ["windowed", "minimal-ui", "standalone"],
  "orientation": "any",
  "theme_color": "#0A0A0F",
  "background_color": "#0A0A0F",
  "dir": "rtl",
  "lang": "ar-SA",
  "categories": ["business", "productivity", "finance", "utilities"],
  "prefer_related_applications": false,
  "icons": [
    {
      "src": "/assets/icons/icon-72x72.svg",
      "sizes": "72x72",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/assets/icons/icon-96x96.svg",
      "sizes": "96x96",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/assets/icons/icon-128x128.svg",
      "sizes": "128x128",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/assets/icons/icon-144x144.svg",
      "sizes": "144x144",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/assets/icons/icon-152x152.svg",
      "sizes": "152x152",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/assets/icons/icon-192x192.svg",
